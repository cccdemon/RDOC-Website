<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Raumdock – Star Citizen Orga</title>
  <meta name="description" content="Raumdock ist eine deutschsprachige Star Citizen Orga. Tritt unserem Discord bei, nimm an Events teil und lerne uns kennen." />
  <meta property="og:title" content="Raumdock – Star Citizen Orga" />
  <meta property="og:description" content="Tritt unserem Discord bei, nimm an Events teil und lerne uns kennen." />
  <meta property="og:type" content="website" />
  <meta name="theme-color" content="#0a0a0a" />
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Cg fill='none' stroke='black' stroke-width='0'%3E%3Ccircle cx='50' cy='50' r='48' fill='%230a0a0a'/%3E%3Cpath d='M22 62 q28 14 56 0 l-6-22 q-24-10-44 0 z' fill='%23444'/%3E%3Cellipse cx='50' cy='46' rx='26' ry='18' fill='%23f6c200'/%3E%3Cellipse cx='62' cy='40' rx='8' ry='5' fill='%23fff7'/%3E%3C/g%3E%3C/svg%3E" />
  <style>
    :root{
      /* Farbwelt orientiert an den bereitgestellten Assets (gelber Visor, Dunkelgrau/Schwarz, dezente Highlights) */
      --bg:#08090c;            /* fast schwarz */
      --bg2:#0f1116;           /* tiefes Grau */
      --fg:#f4f6f8;            /* sehr helles Grau für Text */
      --muted:#b7beca;         /* gedämpftes Grau */
      --accent:#f6c200;        /* Visor-Gelb */
      --accent2:#ffe585;       /* helles Gelb-Highlight */
      --card:#11141b;          /* Kartenhintergrund */
      --border:#222832;        /* Rahmenfarbe */
    }
    *{box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{margin:0; font-family:system-ui,-apple-system,Segoe UI,Roboto,Ubuntu,Inter,Helvetica,Arial,sans-serif; color:var(--fg); background: radial-gradient(1200px 600px at 20% -10%, #10141d 0%, transparent 60%), radial-gradient(1000px 600px at 120% 10%, #0b0f18 0%, transparent 60%), var(--bg);}
    header{position:sticky; top:0; z-index:50; backdrop-filter:saturate(150%) blur(8px); background:linear-gradient(180deg, rgba(7,11,22,.9), rgba(7,11,22,.6)); border-bottom:1px solid var(--border)}
    .container{max-width:1080px; margin-inline:auto; padding:0 20px}
    nav{display:flex; align-items:center; justify-content:space-between; gap:12px; height:64px}
    .brand{display:flex; align-items:center; gap:10px; font-weight:700; letter-spacing:.3px}
    .brand .logo{width:28px; height:28px; border-radius:6px; background:linear-gradient(145deg, var(--accent), var(--accent2)); box-shadow:0 0 24px rgba(246,194,0,.45), inset 0 0 12px rgba(0,0,0,.5)}
    .menu a{color:var(--fg); text-decoration:none; padding:8px 12px; border-radius:12px; font-size:14px}
    .menu a:hover{background:rgba(255,255,255,.05)}
    .cta{background:linear-gradient(90deg, var(--accent), var(--accent2)); color:#00111a; font-weight:700}
    .hero{position:relative; padding:96px 0 72px; overflow:hidden; border-bottom:1px solid var(--border)}
    .hero .grid{display:grid; grid-template-columns:1.1fr .9fr; gap:32px}
    .chip{display:inline-flex; align-items:center; gap:8px; font-size:12px; padding:6px 10px; border:1px solid var(--border); border-radius:999px; color:var(--muted); background:rgba(255,255,255,.03)}
    h1{font-size:clamp(28px, 4.2vw, 48px); line-height:1.1; margin:10px 0 12px}
    p.lead{color:var(--muted); font-size:18px; margin:0 0 22px}
    .cards{display:grid; grid-template-columns:repeat(3,1fr); gap:16px; margin-top:26px}
    .card{background:linear-gradient(180deg, rgba(14,22,48,.9), rgba(14,22,48,.6)); border:1px solid var(--border); border-radius:16px; padding:18px}
    .card h3{margin:4px 0 6px; font-size:16px}
    section{padding:72px 0; border-bottom:1px solid var(--border)}
    section h2{font-size:28px; margin:0 0 12px}
    section p{color:var(--muted)}
    .list{display:grid; gap:10px; margin:14px 0 0}
    .list a{display:flex; justify-content:space-between; align-items:center; gap:12px; text-decoration:none; color:var(--fg); padding:14px 16px; border:1px solid var(--border); border-radius:14px; background:rgba(255,255,255,.02)}
    .list a:hover{background:rgba(255,255,255,.06)}
    .pill{font-size:12px; color:#00111a; background:linear-gradient(90deg, var(--accent), var(--accent2)); padding:4px 10px; border-radius:999px}
    .grid-2{display:grid; grid-template-columns:1fr 1fr; gap:24px}
    .footer{padding:28px 0 60px; color:var(--muted)}
    .notice{font-size:13px; color:#9fb4d6; background:rgba(0,194,255,.06); border:1px dashed var(--accent); border-radius:12px; padding:12px 14px}
    .discord-embed{aspect-ratio:16/9; width:100%; border:0; border-radius:14px; overflow:hidden; background:#23272a}
    /* Mobile */
    .burger{display:none}
    @media (max-width: 860px){
      .hero .grid{grid-template-columns:1fr}
      .cards{grid-template-columns:1fr}
      .grid-2{grid-template-columns:1fr}
      .menu{display:none}
      .burger{display:inline-flex; gap:8px; align-items:center; cursor:pointer; background:transparent; border:1px solid var(--border); color:var(--fg); padding:8px 10px; border-radius:12px}
      .drawer{position:fixed; inset:0 0 auto auto; width:100%; height:100%; background:rgba(7,11,22,.9); backdrop-filter:blur(6px); display:none}
      .drawer nav{flex-direction:column; padding:20px}
      .drawer a{font-size:18px; padding:14px 12px; width:100%}
    }
  </style>
</head>
<body>
  <header>
    <div class="container">
      <nav>
        <div class="brand"><span class="logo" aria-hidden="true"></span><span>Raumdock</span></div>
        <div class="menu" aria-label="Hauptmenü">
          <a href="#willkommen">Willkommen</a>
          <a href="#wir-sind">Wir sind</a>
         <!---  <a href="#discord-event">Discord&nbsp;Event</a> -->
          <a href="#links">Links</a>
          <a href="#twitch">Twitch</a>
          <a href="#disclaimer">Disclaimer</a>
          <a href="#impressum" class="cta">Impressum</a>
        </div>
        <button class="burger" id="burger" aria-label="Menü öffnen">☰ Menü</button>
      </nav>
    </div>
  </header>

  <div class="drawer" id="drawer" aria-hidden="true">
    <div class="container">
      <nav>
        <a href="#willkommen">Willkommen</a>
        <a href="#wir-sind">Wir sind</a>
        <a href="#discord-event">Discord Event</a>
        <a href="#links">Links</a>
        <a href="#twitch">Twitch</a>
        <a href="#disclaimer">Disclaimer</a>
        <a href="#impressum">Impressum</a>
      </nav>
    </div>
  </div>

  <main>
    <!-- Willkommen -->
    <section id="willkommen" class="hero">
      <div class="container grid">
        <div>
          <span class="chip">Willkommen bei der Star Citizen Orga</span>
          <h1>Raumdock</h1>
          <h2 style="margin:10px 0 6px; font-size:22px; color:var(--accent)">Unsere Vision</h2>
          <p class="lead"><br>Eine Orga ist eine Gemeinschaft und eine Gemeinschaft lebt von den Menschen die ihr angehören.<br>Wir verfolgen ein gemeinsames Ziel, eine Vision wie wie spielen wollen, wer wir sein wollen.<br>Jeder von uns ist wichtig, jeder von uns kann und soll gestalten.<br>Das grundsätzlich Prinzip sollte sein: Fordern und Fördern. Es ist ein Geben und ein Nehmen.<br>Ohne Euch entsteht keine Gesellschaft</p>
          <div class="cards">
            <div class="card"><h3>🔭 Fokus</h3><p>Kooperative PvE‑Aktivitäten, Event‑Abende und Hilfe für neue Piloten.</p></div>
            <div class="card"><h3>🛰️ Spielstil</h3><p>Casual bis organisiert – real life first. Keine Pflichttermine.</p></div>
            <div class="card"><h3>💬 Community</h3><p>Discord als Heimatbasis mit Voice‑Kanälen und Terminplanung.</p></div>
          </div>
        </div>
        <div>
          <div class="card">
            <h3>Beitreten</h3>
            <p class="lead">Komm auf unseren Discord und sag Hallo!</p>
            <div class="list">
              <!-- TODO: Ersetze die Platzhalter-URLs durch eure echten Links. -->
              <a href="https://discord.gg/justcallmedeimos" target="_blank" rel="noopener">
                <span>Discord beitreten</span>
                <span class="pill">Invite</span>
              </a>
              <a href="https://robertsspaceindustries.com/orgs/RDOC" target="_blank" rel="noopener">
                <span>RSI Orga‑Seite</span>
                <span class="pill">RSI</span>
              </a>
             <!-- <a href="#discord-event">
                <span>Nächste Events</span>
                <span class="pill">Kalender</span>
              </a> -->
            </div>
            </div>
        </div>
      </div>
    </section>

    <!-- Wir sind -->
    <section id="wir-sind">
      <div class="container grid-2">
        <div>
          <h2>Wir sind</h2>
          <p>Eine bunt gemischte Crew aus Veteranen und Neulingen. Bei uns steht Teamplay, Hilfsbereitschaft und Spaß im Verse im Vordergrund. Wir fliegen regelmäßig gemeinsam, teilen Wissen und bauen an Projekten – vom Mining‑Konvoi bis zur Foto‑Tour.</p>
          <ul class="list" style="list-style:none; padding:0">
            </ul>
        </div>
        <div>
          <div class="card">
            <h3>Aufnahme & Regeln</h3>
            <p class="lead">Respektvoller Umgang, keine Cheats/Exploits, real life geht vor. Mindestalter 18+ empfohlen.</p>
            </div>
        </div>
      </div>
    </section>

    <!-- Discord Event -->
<!--    <section id="discord-event">
      <div class="container">
        <h2>Discord Event</h2>
        <p>Die nächsten Termine werden direkt aus unserem Discord geladen.</p>
        <div id="discord-events" class="list" style="margin-top:16px"></div>
      </div>
    </section>
            <iframe
              class="discord-embed"
              src="https://discord.com/widget?id=1431307397842079777&theme=dark"
              allowtransparency="true"
              sandbox="allow-popups allow-popups-to-escape-sandbox allow-same-origin allow-scripts"
              title="Discord Widget"></iframe>
          </div>
          <div>
            <div class="card">
              <h3>Nächster Event‑Abend</h3>
              <p class="lead">Jeden Freitag, 20:00 Uhr – gemeinsames Fliegen (optional). Treffpunkt: Discord.</p>
              <div class="list">
                <a href="https://discord.com/channels/@me" target="_blank" rel="noopener"><span>Zum Event‑Channel</span><span class="pill">Discord</span></a>
                <a href="https://calendar.google.com" target="_blank" rel="noopener"><span>In Kalender speichern</span><span class="pill">ICS</span></a>
              </div>
              </div>
          </div>
        </div>
      </div>
    </section> -->

    <!-- Links -->
    <section id="links">
      <div class="container">
        <h2>Links</h2>
        <p>Praktische Verweise rund um Raumdock und Star Citizen.</p>
        <div class="list" style="margin-top:16px">
          <a href="https://discord.gg/justcallmedeimos" target="_blank" rel="noopener"><span>Discord</span><span class="pill">Invite</span></a>
          <a href="https://robertsspaceindustries.com/orgs/RDOC" target="_blank" rel="noopener"><span>RSI Orga‑Seite</span><span class="pill">RSI</span></a>
          <a href="https://robertsspaceindustries.com/spectrum/community/SC" target="_blank" rel="noopener"><span>Spectrum</span><span class="pill">Forum</span></a>
          <a href="https://uexcorp.space/" target="_blank" rel="noopener"><span>UEX</span><span class="pill">Trading</span></a>
          <a href="https://ccugame.app/" target="_blank" rel="noopener"><span>CCU Game</span><span class="pill">Tools</span></a>
        </div>
        </div>
    </section>

    <!-- Twitch -->
    <section id="twitch">
      <div class="container">
        <h2>Twitch – Raumdock Streamer</h2>
        <p>Hier kannst du dem Raumdock‑Streamer <strong>JustCallMeDeimos</strong> live zuschauen und weitere großartige Star Citizen Creator entdecken.</p>
        <div class="grid-2" style="margin-top:20px">
          <div>
            <!-- Twitch Embed: JustCallMeDeimos -->
            <iframe
              src="https://player.twitch.tv/?channel=JustCallMeDeimos&parent=raumdock.org"
              class="discord-embed"
              allowfullscreen>
            </iframe>
          </div>
          <div>
            <div class="card">
              <h3>Empfohlene Streamer</h3>
              <p class="lead">Unterstütze unsere Freunde im Verse:</p>
              <div class="list">
                <a href="https://twitch.tv/SunaDevi" target="_blank" rel="noopener"><span>SunaDevi</span><span class="pill">Twitch</span></a>
                <a href="https://twitch.tv/Hexenwerk_Gaming" target="_blank" rel="noopener"><span>Hexenwerk_Gaming</span><span class="pill">Twitch</span></a>
                <a href="https://twitch.tv/jenniferhof_aka_toxona" target="_blank" rel="noopener"><span>jenniferhof_aka_toxona</span><span class="pill">Twitch</span></a>
                <a href="https://twitch.tv/Casishur" target="_blank" rel="noopener"><span>Casishur</span><span class="pill">Twitch</span></a>
                <a href="https://twitch.tv/Vi5E" target="_blank" rel="noopener"><span>Vi5E</span><span class="pill">Twitch</span></a>
              </div>
              </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Disclaimer -->
    <section id="disclaimer">
      <div class="container">
        <h2>Disclaimer</h2>
        <p>Raumdock ist eine inoffizielle, von Spielern organisierte Community und steht in keiner offiziellen Verbindung zu Cloud Imperium Games (CIG) oder Roberts Space Industries (RSI). Alle Marken und eingetragenen Warenzeichen sind Eigentum der jeweiligen Inhaber.</p>
        </div>
    </section>

    <!-- Impressum -->
    <section id="impressum">
      <div class="container">
        <h2>Impressum</h2>
        <div class="grid-2">
          <div>
            <p><strong>Verantwortlich für den Inhalt:</strong><br>
            <span>Torsten Ennenbach</span><br>
            <span>Bahnhofstraße 39</span><br>
            <span>53757 Sankt Augustin</span><br>
            <span>Deutschland</span><br>
            <span>E‑Mail: tower@raumdock.org</span></p>
          </div>
          <div>
            <div class="card">
              <h3>Hinweise zum Impressum</h3>
              <p class="lead">Diese Vorlage bietet keinen Rechtsrat. Je nach Rechtsform (z.&nbsp;B. Verein) können zusätzliche Angaben erforderlich sein. Prüfe die Impressumspflichten in deinem Land (z.&nbsp;B. §5 TMG in DE).</p>
              </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="container" style="display:flex; justify-content:space-between; gap:12px; align-items:center; flex-wrap:wrap">
      <div>© <span id="year"></span> Raumdock – Star Citizen Orga</div>
      <div style="opacity:.7">Made with ❤️ im Verse</div>
    </div>
  </footer>

  <script>
    // Jahr im Footer
    document.getElementById('year').textContent = new Date().getFullYear();

    // Mobiles Menü
    const burger = document.getElementById('burger');
    const drawer = document.getElementById('drawer');
    if(burger && drawer){
      burger.addEventListener('click', () => {
        const open = drawer.style.display === 'block';
        drawer.style.display = open ? 'none' : 'block';
        drawer.setAttribute('aria-hidden', open ? 'true' : 'false');
      });
      drawer.addEventListener('click', (e) => {
        if(e.target.tagName === 'A' || e.target === drawer){
          drawer.style.display = 'none';
          drawer.setAttribute('aria-hidden', 'true');
        }
      });
    }
  </script>

  <script>
    async function loadDiscordEvents(){
      try{
        const res = await fetch('/api/discord-events.php', {cache:'no-store'});
        if(!res.ok) throw new Error('HTTP '+res.status);
        const items = await res.json();
        const wrap = document.getElementById('discord-events');
        wrap.innerHTML = '';
        if(!items.length){
          const p = document.createElement('p');
          p.textContent = 'Aktuell sind keine Events geplant.';
          wrap.appendChild(p);
          return;
        }
        const fmt = new Intl.DateTimeFormat('de-DE', {weekday:'short', day:'2-digit', month:'2-digit', hour:'2-digit', minute:'2-digit'});
        items.forEach(ev => {
          const a = document.createElement('a');
          a.className = 'event-row';
          a.href = ev.url || '#';
          a.target = '_blank';
          a.rel = 'noopener';
          a.style = 'display:flex;justify-content:space-between;align-items:center;gap:12px;text-decoration:none;color:inherit;padding:14px 16px;border:1px solid var(--border);border-radius:14px;background:rgba(255,255,255,.02);margin:8px 0;';
          a.innerHTML = `
            <span>
              <strong>${ev.name}</strong><br>
              <small>${fmt.format(new Date(ev.start_time))}${ev.end_time ? ' – ' + fmt.format(new Date(ev.end_time)) : ''}${ev.location ? ' · ' + ev.location : ''}</small>
              ${ev.description ? `<br><small style="opacity:.8">${ev.description.substring(0,140)}${ev.description.length>140?'…':''}</small>`:''}
            </span>
            <span class="pill">Discord</span>
          `;
          wrap.appendChild(a);
        });
      }catch(e){
        const wrap = document.getElementById('discord-events');
        if (wrap) wrap.innerHTML = '<p>Events konnten nicht geladen werden.</p>';
      }
    }
    loadDiscordEvents();
  </script>
</body>
</html>
